# ============================================================
# STOCK PREDICTION PROJECT - COMPLETE .gitignore
# ============================================================

# ============================================================
# DATA FILES
# ============================================================
data/
!data/.gitkeep
data/raw/*.csv
data/raw/*.parquet
data/raw/*.feather
data/processed/*.csv
data/processed/*.parquet
data/processed/*.feather
data/cache/
data/temp/

# ============================================================
# MODELS
# ============================================================
models/
!models/.gitkeep
models/*.pkl
models/*.h5
models/*.pb
models/*.onnx
models/*.joblib
models/*.pth
models/*.pt
models/*_metadata.json
models/*_metrics.json
models/best_model/

# ============================================================
# OUTPUTS & REPORTS
# ============================================================
outputs/
!outputs/.gitkeep
outputs/predictions/*.csv
outputs/predictions/*.txt
outputs/figures/*.png
outputs/figures/*.jpg
outputs/figures/*.pdf
outputs/figures/*.html
outputs/reports/
outputs/*.log

# ============================================================
# LOGS
# ============================================================
logs/
!logs/.gitkeep
logs/*.log
logs/*.txt
*.log

# ============================================================
# PYTHON CACHE
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo
*.pyd

# ============================================================
# VIRTUAL ENVIRONMENTS
# ============================================================
venv/
env/
ENV/
env.bak/
venv.bak/
pythonenv*
.venv
virtualenv/
pyenv/

# ============================================================
# DEPENDENCIES
# ============================================================
requirements.txt
!requirements.txt
Pipfile
Pipfile.lock
poetry.lock
pyproject.toml
!pyproject.toml

# ============================================================
# JUPYTER NOTEBOOKS
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb
!01_exploration.ipynb
!02_feature_analysis.ipynb
!03_experiments.ipynb
!dashboard.ipynb
jupyter_notebook_config.py

# ============================================================
